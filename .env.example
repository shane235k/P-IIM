# Primary API Key
GEMINI_API_KEY=

# Rate-limit Distribution Keys (Intake, Workers, Judge nodes)
GEMINI_API_KEY_PRIMARY=
GEMINI_API_KEY_WORKERS=
GEMINI_API_KEY_JUDGE=

# Models Config
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_REASONING_MODEL=gemini-2.5-flash-lite

# Fallback Provider (Groq)
GROQ_API_KEY=
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Web scraper
TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=

# SEC API Config
SEC_EDGAR_USER_AGENT=AIInvestmentResearchAgent shanewillplay@gmail.com

# PostgreSQL database URL
DATABASE_URL=

# LangSmith Tracing (Optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=investment-thesis-stress-test
LANGSMITH_TRACING=false

# Cost / safety controls
MAX_RESEARCH_LOOPS=2
MAX_TOOL_CALLS_PER_RUN=30
MAX_RUN_COST_USD_ESTIMATE=1.00
REQUEST_TIMEOUT_MS=30000

NODE_ENV=development
